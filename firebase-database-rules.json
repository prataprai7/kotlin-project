{
  "rules": {
    "users": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "$userId === auth.uid"
      }
    },
    "tasks": {
      "$taskId": {
        ".read": "auth != null && data.child('userId').val() === auth.uid",
        ".write": "auth != null && (data.child('userId').val() === auth.uid || newData.child('userId').val() === auth.uid)"
      }
    },
    "categories": {
      "$categoryId": {
        ".read": "auth != null && data.child('userId').val() === auth.uid",
        ".write": "auth != null && (data.child('userId').val() === auth.uid || newData.child('userId').val() === auth.uid)"
      }
    }
  }
}